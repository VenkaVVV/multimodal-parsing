# 应用配置
APP_NAME=multimodal-parsing
APP_VERSION=0.1.0
DEBUG=false

# 解析器配置
PARSER_MODE=traditional
MAX_FILE_SIZE=104857600

# MinerU配置
MINERU_DEVICE=cuda:0
MINERU_MODELS_DIR=models/
MINERU_OUTPUT_DIR=output/

# LibreOffice配置
LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
LIBREOFFICE_TIMEOUT=60

# 分片配置
CHUNKING_ENABLED=false
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# 快照配置
SNAPSHOT_ENABLED=true
SNAPSHOT_DPI=150

# API配置
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# VLM配置（可选）
VLM_MODEL=deepseek-vl2
DEEPSEEK_API_KEY=your_api_key_here
